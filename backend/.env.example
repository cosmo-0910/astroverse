# Google Gemini API Key for AI readings and Astrologer chat
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Supabase or local PostgreSQL connection URL
# Example: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/astroverse

# Secure random 32-byte hexadecimal string for JWT token signatures
# Generate via: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECURE_JWT_SECRET_KEY_HERE
